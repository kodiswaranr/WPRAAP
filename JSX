              <div style={{minWidth:22,height:22,borderRadius:6,background:SOFT,display:"flex",alignItems:"center",justifyContent:"center",fontWeight:800,fontSize:11,color:BLUE}}>{i+1}</div>
              <div style={{flex:"1 1 150px"}}>
                <div style={{fontWeight:700,fontSize:13,color:"#0f2a4a"}}>{p.fullname}</div>
                <div style={{fontSize:11,color:TMUTED,marginTop:1}}>{p.iqamaNo}</div>
              </div>
              <div style={{display:"flex",gap:5,flexWrap:"wrap",flex:"2 1 240px"}}>
                {e.permitNo&&<span style={{background:"#dbeafe",color:"#1d4ed8",padding:"2px 8px",borderRadius:5,fontSize:11,fontWeight:700}}>🪪 {e.permitNo}</span>}
                {e.location&&e.location!=="Stand by"&&<span style={{background:SOFT,color:TSUB,padding:"2px 8px",borderRadius:5,fontSize:11}}>📍 {e.location}</span>}
                {e.permitStatus&&<span style={{color:psColor(e.permitStatus),fontSize:11,fontWeight:700}}>{e.permitStatus}</span>}
                {e.remarks&&<span style={{color:rmColor(e.remarks),fontSize:11,fontWeight:600}}>{rmIcon(e.remarks)} {e.remarks}</span>}
                {!upd&&<span style={{color:"#c62828",fontSize:11}}>⚠️ Not updated</span>}
              </div>
              <div style={{display:"flex",gap:6,alignItems:"center"}}>
                {upd&&<span style={{fontSize:10,color:"#2e7d32"}}>✅ {new Date(e.updatedAt).toLocaleTimeString([],{hour:"2-digit",minute:"2-digit"})}</span>}
                <button onClick={()=>openEdit(p)}
                  style={{background:upd?"#e8f5e9":BLUE,border:upd?"1px solid #a5d6a7":"none",borderRadius:7,padding:"6px 13px",color:upd?"#2e7d32":"#fff",fontSize:12,fontWeight:700,cursor:"pointer",whiteSpace:"nowrap"}}>
                  {upd?"✏️ Edit":"📝 Update"}
                </button>
              </div>
            </div>
          );
        })}
      </div>
    </>)}

    {/* ══ HISTORY ══ */}
    {view==="history" && (<>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:16,flexWrap:"wrap",gap:10}}>
        <div>
          <h2 style={{fontSize:19,fontWeight:800,color:"#0f2a4a",margin:"0 0 2px"}}>History</h2>
          <p style={{color:TSUB,fontSize:13,margin:0}}>View & export past records</p>
        </div>
        <div style={{display:"flex",gap:10,alignItems:"center"}}>
          <input type="date" value={histDate} onChange={e=>setHistDate(e.target.value)}
            style={{background:CARD,border:"1px solid "+INPBDR,borderRadius:8,padding:"7px 12px",color:"#0f2a4a",fontSize:13,outline:"none"}}/>
          <button onClick={()=>exportCSV(personnel,hLog,histDate)}
            style={{background:SOFT,border:"1px solid "+CBDR,borderRadius:8,padding:"7px 13px",color:BLUE,fontSize:12,fontWeight:700,cursor:"pointer"}}>
            ⬇ Export CSV
          </button>
        </div>
      </div>
      <div style={{background:CARD,border:"1px solid "+CBDR,borderRadius:12,overflow:"hidden",boxShadow:"0 1px 5px #1565a010"}}>
        <div style={{overflowX:"auto"}}>
          <table style={{width:"100%",borderCollapse:"collapse",fontSize:13}}>
            <thead>
              <tr style={{background:"#dbeafe"}}>
                {["#","Iqama No","Full Name","Permit No","Location","Permit Status","Remarks","Updated At"].map(h=>(
                  <th key={h} style={{padding:"9px 11px",textAlign:"left",color:TSUB,fontWeight:700,fontSize:10,letterSpacing:0.8,textTransform:"uppercase",whiteSpace:"nowrap"}}>{h}</th>
                ))}
              </tr>
            </thead>
            <tbody>
              {personnel.map((p,i)=>{
                const e=hLog[p.id];
                return (
                  <tr key={p.id} style={{borderTop:"1px solid "+CBDR,background:i%2===0?CARD:TROW}}>
                    <td style={{padding:"8px 11px",color:TMUTED,fontWeight:600}}>{i+1}</td>
                    <td style={{padding:"8px 11px",color:TSUB,fontSize:11}}>{p.iqamaNo}</td>
                    <td style={{padding:"8px 11px",fontWeight:700,color:"#0f2a4a"}}>{p.fullname}</td>
                    <td style={{padding:"8px 11px"}}>{e?.permitNo?<span style={{color:"#1d4ed8",fontWeight:700}}>{e.permitNo}</span>:<span style={{color:TMUTED}}>—</span>}</td>
                    <td style={{padding:"8px 11px",color:TSUB,fontSize:12}}>{e?.location||"—"}</td>
                    <td style={{padding:"8px 11px"}}>{e?.permitStatus?<span style={{color:psColor(e.permitStatus),fontWeight:700,fontSize:11}}>{e.permitStatus}</span>:<span style={{color:TMUTED}}>—</span>}</td>
                    <td style={{padding:"8px 11px"}}>{e?.remarks?<span style={{color:rmColor(e.remarks),fontSize:11,fontWeight:600}}>{rmIcon(e.remarks)} {e.remarks}</span>:<span style={{color:TMUTED}}>—</span>}</td>
                    <td style={{padding:"8px 11px",fontSize:11,color:e?.updatedAt?"#2e7d32":"#c62828"}}>{e?.updatedAt?new Date(e.updatedAt).toLocaleTimeString([],{hour:"2-digit",minute:"2-digit"}):"Not Updated"}</td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </div>
    </>)}

    {/* ══ PERSONNEL ══ */}
    {view==="personnel" && (<>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:16}}>
        <div>
          <h2 style={{fontSize:19,fontWeight:800,color:"#0f2a4a",margin:"0 0 2px"}}>Personnel List</h2>
          <p style={{color:TSUB,fontSize:13,margin:0}}>{personnel.length} records</p>
        </div>
        <button onClick={()=>setShowNew(true)}
          style={{background:BLUE,border:"none",borderRadius:8,padding:"8px 17px",color:"#fff",fontWeight:700,fontSize:13,cursor:"pointer"}}>
          + Add New Person
        </button>
      </div>
      {showNew&&(
        <div style={{background:CARD,border:"1px solid "+BLUE,borderRadius:12,padding:18,marginBottom:18,boxShadow:"0 2px 10px #1565a015"}}>
          <div style={{fontWeight:700,color:BLUE,marginBottom:12,fontSize:13}}>➕ New Personnel Record</div>
          <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:11,marginBottom:11}}>
            <div><label style={LBL}>Iqama No *</label><input value={newForm.iqamaNo} onChange={e=>setNewForm(f=>({...f,iqamaNo:e.target.value}))} placeholder="Iqama number" style={INP}/></div>
            <div><label style={LBL}>Full Name *</label><input value={newForm.fullname} onChange={e=>setNewForm(f=>({...f,fullname:e.target.value}))} placeholder="Full name" style={INP}/></div>
            <div><label style={LBL}>Position</label><select value={newForm.position} onChange={e=>setNewForm(f=>({...f,position:e.target.value}))} style={INP}>{POSITIONS.map(p=><option key={p}>{p}</option>)}</select></div>
            <div><label style={LBL}>Delegation Status</label><select value={newForm.delegationStatus} onChange={e=>setNewForm(f=>({...f,delegationStatus:e.target.value}))} style={INP}>{DELEG_STATUS.map(s=><option key={s}>{s}</option>)}</select></div>
          </div>
          <div style={{display:"flex",gap:9}}>
            <button onClick={addPerson} style={{background:BLUE,border:"none",borderRadius:7,padding:"8px 18px",color:"#fff",fontWeight:700,fontSize:13,cursor:"pointer"}}>Save</button>
            <button onClick={()=>{setShowNew(false);setNewForm(emptyPF);}} style={{background:BG,border:"1px solid "+INPBDR,borderRadius:7,padding:"8px 14px",color:TSUB,fontSize:13,cursor:"pointer"}}>Cancel</button>
          </div>
        </div>
      )}
      <div style={{display:"flex",flexDirection:"column",gap:7}}>
        {personnel.map((p,i)=>{ const db=delBadge(p.delegationStatus); return (
          <div key={p.id} style={{background:CARD,border:"1px solid "+CBDR,borderRadius:10,padding:"11px 15px",display:"flex",alignItems:"center",gap:11,flexWrap:"wrap",boxShadow:"0 1px 4px #1565a008"}}>
            <div style={{minWidth:22,height:22,borderRadius:6,background:SOFT,display:"flex",alignItems:"center",justifyContent:"center",fontWeight:800,fontSize:11,color:BLUE}}>{i+1}</div>
            <div style={{flex:1,minWidth:150}}>
              <div style={{fontWeight:700,fontSize:13,color:"#0f2a4a"}}>{p.fullname}</div>
              <div style={{fontSize:11,color:TMUTED,marginTop:1}}>{p.iqamaNo} · {p.position}</div>
            </div>
            <span style={{background:db.bg,color:db.color,padding:"3px 9px",borderRadius:20,fontSize:11,fontWeight:700,whiteSpace:"nowrap"}}>
              {p.delegationStatus==="Delegation letter Active"?"✅ Active":p.delegationStatus==="Waiting for Delegation letter"?"⏳ Waiting":"❌ Expired"}
            </span>
            <button onClick={()=>setDelId(p.id)} style={{background:"#ffebee",border:"1px solid #ffcdd2",color:"#c62828",borderRadius:6,padding:"4px 10px",fontSize:11,cursor:"pointer",fontWeight:600}}>Remove</button>
          </div>
        );})}
      </div>
    </>)}
  </div>

  {/* Entry Modal */}
  {editEntry&&(
    <div style={{position:"fixed",inset:0,background:"#1565a044",display:"flex",alignItems:"center",justifyContent:"center",zIndex:100,padding:16}}>
      <div style={{background:CARD,border:"1px solid "+BLUE,borderRadius:14,padding:22,width:"100%",maxWidth:450,boxShadow:"0 8px 32px #1565a033"}}>
        <div style={{fontWeight:800,fontSize:15,color:BLUE,marginBottom:2}}>📝 Update Permit Entry</div>
        <div style={{fontSize:13,color:TSUB,marginBottom:16}}>{editEntry.fullname}</div>
        <div style={{display:"flex",flexDirection:"column",gap:11}}>
          <div><label style={LBL}>Permit No</label><input value={entryForm.permitNo||""} onChange={e=>setEntryForm(f=>({...f,permitNo:e.target.value}))} placeholder="e.g. 8314344" style={INP}/></div>
          <div><label style={LBL}>Location</label><input value={entryForm.location||""} onChange={e=>setEntryForm(f=>({...f,location:e.target.value}))} placeholder="e.g. WIPS 321 STR #161C" style={INP}/></div>
          <div><label style={LBL}>Permit Status</label><select value={entryForm.permitStatus||"Active"} onChange={e=>setEntryForm(f=>({...f,permitStatus:e.target.value}))} style={INP}>{PERMIT_STATUS_OPTS.map(s=><option key={s}>{s}</option>)}</select></div>
          <div><label style={LBL}>Remarks</label><select value={entryForm.remarks||"Active"} onChange={e=>setEntryForm(f=>({...f,remarks:e.target.value}))} style={INP}>{REMARKS_OPTS.map(r=><option key={r}>{r}</option>)}</select></div>
        </div>
        <div style={{display:"flex",gap:9,marginTop:16}}>
          <button onClick={saveEntry} style={{flex:1,background:BLUE,border:"none",borderRadius:8,padding:10,color:"#fff",fontWeight:700,fontSize:13,cursor:"pointer"}}>Save Entry</button>
          <button onClick={()=>setEditEntry(null)} style={{background:BG,border:"1px solid "+INPBDR,borderRadius:8,padding:"10px 16px",color:TSUB,fontSize:13,cursor:"pointer"}}>Cancel</button>
        </div>
      </div>
    </div>
  )}

  {/* Delete confirm */}
  {delId&&(
    <div style={{position:"fixed",inset:0,background:"#00000066",display:"flex",alignItems:"center",justifyContent:"center",zIndex:100}}>
      <div style={{background:CARD,border:"1px solid "+CBDR,borderRadius:12,padding:24,maxWidth:330,width:"90%",boxShadow:"0 8px 24px #1565a022"}}>
        <div style={{fontSize:15,fontWeight:700,color:"#0f2a4a",marginBottom:7}}>Remove Personnel?</div>
        <div style={{color:TSUB,fontSize:13,marginBottom:16}}>This cannot be undone.</div>
        <div style={{display:"flex",gap:9}}>
          <button onClick={()=>delPerson(delId)} style={{flex:1,background:"#c62828",border:"none",borderRadius:8,padding:9,color:"#fff",fontWeight:700,cursor:"pointer"}}>Remove</button>
          <button onClick={()=>setDelId(null)} style={{flex:1,background:BG,border:"1px solid "+INPBDR,borderRadius:8,padding:9,color:TSUB,cursor:"pointer"}}>Cancel</button>
        </div>
      </div>
    </div>
  )}

  {/* Toast */}
  {toast&&(
    <div style={{position:"fixed",bottom:22,right:22,background:toast.type==="err"?"#ffebee":"#e8f5e9",border:"1px solid "+(toast.type==="err"?"#ffcdd2":"#a5d6a7"),borderRadius:10,padding:"10px 16px",color:toast.type==="err"?"#c62828":"#2e7d32",fontWeight:700,fontSize:13,zIndex:200,boxShadow:"0 4px 14px #1565a022"}}>
      {toast.type==="err"?"⚠️":"✅"} {toast.msg}
    </div>
  )}
</div>
