function exportCSV(personnel, log, date) {
const rows = [[“No”,“Iqama No”,“Full Name”,“Position”,“Delegation Status”,“Permit No”,“Location”,“Permit Status”,“Remarks”,“Updated At”,“Date”]];
personnel.forEach((p,i) => {
const e = log[p.id]||{};
rows.push([i+1,p.iqamaNo,p.fullname,p.position,p.delegationStatus,
e.permitNo||””,e.location||””,e.permitStatus||””,e.remarks||””,
e.updatedAt?new Date(e.updatedAt).toLocaleTimeString():“Not Updated”,date]);
});
const csv = rows.map(r=>r.map(c=>’”’+String(c).replace(/”/g,’\”’)+’”’).join(”,”)).join(”\n”);
const uri = “data:text/csv;charset=utf-8,”+encodeURIComponent(csv);
const a = document.createElement(“a”);
a.setAttribute(“href”,uri); a.setAttribute(“download”,“WPR_Daily_Report_”+date+”.csv”);
document.body.appendChild(a); a.click(); document.body.removeChild(a);
}

